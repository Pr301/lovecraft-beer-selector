rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Beer catalog is public read-only reference data.
    // Writes only happen via the admin migration script (scripts/migrate-beers-to-firestore.mjs).
    match /beers/{beerId} {
      allow read: if true;
      allow write: if false;
    }

    // BA style guideline reference data (SRM/OG/IBU/ABV/description per style),
    // used as a generic fallback when a specific beer is missing a datapoint.
    // Writes only happen via scripts/migrate-ba-styles-to-firestore.mjs.
    match /styleGuidelines/{styleId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
